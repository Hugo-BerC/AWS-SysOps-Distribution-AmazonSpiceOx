#!/bin/sh
set -eu

command_name="${1:-doctor}"

display_socket_exists() {
    display="$1"
    display_num="${display#localhost}"
    display_num="${display_num#127.0.0.1}"
    display_num="${display_num#:}"
    display_num="${display_num%%.*}"
    [ -n "$display_num" ] || return 1
    [ -S "/tmp/.X11-unix/X$display_num" ]
}

display_ready() {
    display="$1"
    [ -n "$display" ] || return 1

    if command -v xdpyinfo >/dev/null 2>&1; then
        DISPLAY="$display" xdpyinfo >/dev/null 2>&1 && return 0
    fi

    if command -v xset >/dev/null 2>&1; then
        DISPLAY="$display" xset q >/dev/null 2>&1 && return 0
    fi

    case "$display" in
        :*|localhost:*|127.0.0.1:*)
            display_socket_exists "$display"
            ;;
        *)
            return 1
            ;;
    esac
}

select_display() {
    seen=" "

    for candidate in "${ASOX_CLIPBOARD_DISPLAY:-}" "${DISPLAY:-}" :0 :1 :100; do
        [ -n "$candidate" ] || continue
        case "$seen" in
            *" $candidate "*) continue ;;
        esac
        seen="$seen$candidate "

        if display_ready "$candidate"; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    printf '%s\n' "${DISPLAY:-:0}"
    return 1
}

display_value="$(select_display || true)"

print_status() {
    echo "DISPLAY=${DISPLAY:-<unset>}"
    echo "ASOX_CLIPBOARD_DISPLAY=${ASOX_CLIPBOARD_DISPLAY:-<unset>}"
    echo "effective DISPLAY for xclip=$display_value"
    if display_ready "$display_value"; then
        echo "display check: OK"
    else
        echo "display check: FAILED"
    fi
    echo

    echo "[virtio port]"
    if [ -e /dev/virtio-ports/com.redhat.spice.0 ]; then
        ls -l /dev/virtio-ports/com.redhat.spice.0
    else
        echo "missing: /dev/virtio-ports/com.redhat.spice.0"
    fi
    echo

    echo "[spice processes]"
    ps w 2>/dev/null | grep '[s]pice-vdagent' || true
    echo

    echo "[xclip]"
    command -v xclip || true
    echo
}

set_clipboard() {
    if ! command -v xclip >/dev/null 2>&1; then
        echo "asox-clipboard: xclip is not installed" >&2
        exit 1
    fi

    if [ -t 0 ]; then
        printf 'Paste text, then press Enter: ' >&2
        old_stty="$(stty -g 2>/dev/null || true)"
        stty -echo 2>/dev/null || true
        IFS= read -r clipboard_text || clipboard_text=""
        [ -n "$old_stty" ] && stty "$old_stty" 2>/dev/null || true
        printf '\n' >&2
        printf '%s' "$clipboard_text" | DISPLAY="$display_value" xclip -selection clipboard
    else
        DISPLAY="$display_value" xclip -selection clipboard
    fi

    echo "asox-clipboard: guest X11 clipboard updated"
}

read_clipboard() {
    if ! command -v xclip >/dev/null 2>&1; then
        echo "asox-clipboard: xclip is not installed" >&2
        exit 1
    fi

    DISPLAY="$display_value" xclip -selection clipboard -o
}

case "$command_name" in
    doctor|status)
        print_status
        ;;
    set)
        set_clipboard
        ;;
    get|read)
        read_clipboard
        ;;
    *)
        echo "usage: asox-clipboard [doctor|set|get]" >&2
        exit 1
        ;;
esac

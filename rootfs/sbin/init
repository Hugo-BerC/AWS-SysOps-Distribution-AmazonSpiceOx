#!/bin/sh

# AmazonSpiceOx stage 2 init.
# This is the real PID 1 after initramfs mounts the persistent rootfs and runs
# switch_root. It stays intentionally small and readable.

export PATH=/usr/local/sbin:/usr/local/bin:/bin:/sbin:/usr/bin:/usr/sbin
export PS1='arrakis:\w# '
export HOME=/root
export TERM=linux
export ENV=/etc/profile

HOSTNAME_FILE=/etc/hostname
BOOT_LOG=/var/log/boot.log
PROFILE_FILE=/etc/amazonspiceox-profile
RESOLV_CONF=/etc/resolv.conf
ACTIVE_PROFILE=base
SMOKE_MODE=none
SMOKE_STATE_DIR=/var/lib/amazonspiceox/smoke
SMOKE_STATUS_FILE=$SMOKE_STATE_DIR/apt.status
NET_IF=eth0

log() {
    message="[init] $*"
    echo "$message"
    echo "$message" >> "$BOOT_LOG" 2>/dev/null || true
}

interactive_shell() {
    shell_bin="/bin/sh"

    if [ -x /bin/bash ]; then
        shell_bin="/bin/bash"
        export SHELL="$shell_bin"
        if command -v cttyhack >/dev/null 2>&1; then
            setsid cttyhack "$shell_bin" --login
        else
            setsid "$shell_bin" --login </dev/console >/dev/console 2>&1
        fi
        return
    fi

    export SHELL="$shell_bin"
    if command -v cttyhack >/dev/null 2>&1; then
        setsid cttyhack "$shell_bin"
    else
        setsid "$shell_bin" </dev/console >/dev/console 2>&1
    fi
}

set_smoke_status() {
    case "$SMOKE_MODE" in
        apt|net|network|awscli|ssm|terraform|kubectl|docker|ssm-powerconnect)
            ;;
        *)
            return 0
            ;;
    esac
    mkdir -p "$SMOKE_STATE_DIR"
    printf '%s\n' "$1" > "$SMOKE_STATUS_FILE" 2>/dev/null || true
    sync 2>/dev/null || true
}

set_smoke_failure() {
    status_file="$1"
    generic_status="$2"
    label="$3"
    current_status=""

    if [ -f "$status_file" ]; then
        current_status="$(cat "$status_file" 2>/dev/null || true)"
    fi

    case "$current_status" in
        ""|*_INIT_*|*_STARTED)
            printf '%s\n' "$generic_status" > "$status_file" 2>/dev/null || true
            current_status="$generic_status"
            ;;
    esac

    echo "$current_status"
    sync 2>/dev/null || true
    log "$label smoke failed: $current_status"
}

load_profile() {
    if [ -f "$PROFILE_FILE" ]; then
        ACTIVE_PROFILE="$(cat "$PROFILE_FILE")"
    fi
}

read_boot_cmdline() {
    for arg in $(cat /proc/cmdline 2>/dev/null || true); do
        case "$arg" in
            asox.smoke=*)
                SMOKE_MODE="${arg#asox.smoke=}"
                ;;
        esac
    done
}

configure_smoke_paths() {
    case "$SMOKE_MODE" in
        net|network)
            SMOKE_STATUS_FILE="$SMOKE_STATE_DIR/network.status"
            ;;
        awscli)
            SMOKE_STATUS_FILE="$SMOKE_STATE_DIR/awscli.status"
            ;;
        ssm)
            SMOKE_STATUS_FILE="$SMOKE_STATE_DIR/ssm.status"
            ;;
        terraform)
            SMOKE_STATUS_FILE="$SMOKE_STATE_DIR/terraform.status"
            ;;
        kubectl)
            SMOKE_STATUS_FILE="$SMOKE_STATE_DIR/kubectl.status"
            ;;
        docker)
            SMOKE_STATUS_FILE="$SMOKE_STATE_DIR/docker.status"
            ;;
        ssm-powerconnect)
            SMOKE_STATUS_FILE="$SMOKE_STATE_DIR/ssm-powerconnect.status"
            ;;
        apt)
            SMOKE_STATUS_FILE="$SMOKE_STATE_DIR/apt.status"
            ;;
    esac
}

emergency_shell() {
    log "entering emergency shell"
    log "type 'exit' to return to the init recovery loop"

    while true; do
        interactive_shell
        log "emergency shell exited; restarting in 2 seconds"
        sleep 2
    done
}

fail() {
    log "ERROR: $*"
    emergency_shell
}

mount_once() {
    fstype="$1"
    target="$2"

    if grep -qs " $target " /proc/mounts 2>/dev/null; then
        log "$target already mounted"
        return 0
    fi

    mount -t "$fstype" "$fstype" "$target" || fail "could not mount $target"
    log "mounted $target"
}

setup_runtime_dirs() {
    mkdir -p /proc /sys /dev /dev/pts /dev/shm /run /tmp /var/log /var/lib/amazonspiceox /root
    chmod 1777 /tmp
    chmod 1777 /dev/shm 2>/dev/null || true
    : > "$BOOT_LOG" 2>/dev/null || true
}

setup_devices() {
    mount_once devtmpfs /dev
    if ! grep -qs " /dev/pts " /proc/mounts 2>/dev/null; then
        mount -t devpts devpts /dev/pts -o mode=620,ptmxmode=666,gid=5 || fail "could not mount /dev/pts"
        log "mounted /dev/pts"
    fi
    if ! grep -qs " /dev/shm " /proc/mounts 2>/dev/null; then
        mount -t tmpfs tmpfs /dev/shm -o mode=1777,nosuid,nodev || fail "could not mount /dev/shm"
        log "mounted /dev/shm"
    fi

    [ -c /dev/console ] || mknod -m 600 /dev/console c 5 1 2>/dev/null || true
    [ -c /dev/null ] || mknod -m 666 /dev/null c 1 3 2>/dev/null || true
}

setup_cgroups() {
    mkdir -p /sys/fs/cgroup

    if grep -qs " /sys/fs/cgroup " /proc/mounts 2>/dev/null; then
        log "/sys/fs/cgroup already mounted"
        return 0
    fi

    if mount -t cgroup2 cgroup2 /sys/fs/cgroup >/tmp/cgroup2.log 2>&1; then
        log "mounted /sys/fs/cgroup as cgroup2"
        return 0
    fi

    log "cgroup2 mount skipped; see /tmp/cgroup2.log"
}

setup_udev() {
    udevd_bin=""

    for candidate in /lib/systemd/systemd-udevd /usr/lib/systemd/systemd-udevd /sbin/udevd; do
        if [ -x "$candidate" ]; then
            udevd_bin="$candidate"
            break
        fi
    done

    if [ -z "$udevd_bin" ]; then
        log "udev daemon not available"
        return 0
    fi

    "$udevd_bin" --daemon >/tmp/udevd.log 2>&1 || true

    if command -v udevadm >/dev/null 2>&1; then
        udevadm control --reload >/dev/null 2>&1 || true
        udevadm trigger --action=add >/dev/null 2>&1 || true
        udevadm settle >/dev/null 2>&1 || true
    fi

    log "udev initialized"
}

setup_hostname() {
    name="arrakis"

    if [ -f "$HOSTNAME_FILE" ]; then
        name="$(cat "$HOSTNAME_FILE")"
    fi

    hostname "$name" || fail "could not set hostname"
    log "hostname set to $name"
}

network_has_ipv4() {
    net_if="${1:-$NET_IF}"
    ip -4 addr show dev "$net_if" 2>/dev/null | grep -q 'inet '
}

network_has_default_route() {
    ip route show default 2>/dev/null | grep -q '^default '
}

detect_network_if() {
    if ip link show eth0 >/dev/null 2>&1; then
        NET_IF=eth0
        return 0
    fi

    detected_if="$(
        ip -o link show 2>/dev/null | awk -F': ' '$2 != "lo" { print $2; exit }'
    )"

    if [ -n "$detected_if" ]; then
        NET_IF="$detected_if"
        return 0
    fi

    NET_IF=eth0
    return 1
}

setup_network() {
    detect_network_if || true
    log "network interface selected: $NET_IF"

    log "initializing loopback"
    if command -v ifup >/dev/null 2>&1; then
        ifup lo 2>/dev/null || true
    else
        ip link set lo up 2>/dev/null || ifconfig lo 127.0.0.1 up 2>/dev/null || true
    fi

    if command -v ifup >/dev/null 2>&1; then
        if ifup "$NET_IF" >/tmp/ifup-eth0.log 2>&1; then
            if network_has_ipv4 "$NET_IF" && network_has_default_route; then
                log "$NET_IF configured through ifup"
                return 0
            fi
            log "ifup $NET_IF returned success, but IPv4 or default route is still missing"
        else
            log "ifup $NET_IF failed; see /tmp/ifup-eth0.log"
        fi
    fi

    if ip link set "$NET_IF" up 2>/dev/null || ifconfig "$NET_IF" up 2>/dev/null; then
        log "$NET_IF link is up"

        if command -v udhcpc >/dev/null 2>&1; then
            udhcpc -i "$NET_IF" -q -n -t 3 -T 2 >/tmp/udhcpc.log 2>&1 \
                && log "dhcp lease acquired on $NET_IF" \
                || log "dhcp did not complete; see /tmp/udhcpc.log"
        elif command -v dhclient >/dev/null 2>&1; then
            dhclient -v -1 "$NET_IF" >/tmp/dhclient-eth0.log 2>&1 \
                && log "dhcp lease acquired on $NET_IF" \
                || log "dhclient did not complete; see /tmp/dhclient-eth0.log"
        fi

        if network_has_ipv4 "$NET_IF" && network_has_default_route; then
            log "$NET_IF has IPv4 connectivity after DHCP fallback"
        else
            log "$NET_IF still lacks IPv4 connectivity after DHCP fallback"
        fi
    else
        log "$NET_IF not available yet"
    fi
}

setup_resolver() {
    if [ -s "$RESOLV_CONF" ] && grep -q '^nameserver[[:space:]]' "$RESOLV_CONF" 2>/dev/null; then
        log "resolver already configured"
        return 0
    fi

    cat > "$RESOLV_CONF" <<'EOF'
nameserver 10.0.2.3
nameserver 1.1.1.1
EOF
    log "resolver configured with QEMU user-mode DNS fallback"
}

record_persistent_boot() {
    echo "booted from persistent rootfs" > /var/lib/amazonspiceox/rootfs-state
    sync 2>/dev/null || true
    log "persistent rootfs marker written to /var/lib/amazonspiceox/rootfs-state"
}

run_requested_smoke() {
    case "$SMOKE_MODE" in
        ""|none)
            return 0
            ;;
        awscli)
            SMOKE_STATUS_FILE="$SMOKE_STATE_DIR/awscli.status"
            log "running requested awscli smoke"
            set_smoke_status "AMAZONSPICEOX_AWSCLI_INIT_LAUNCHING_SCRIPT"
            if [ ! -x /usr/local/lib/amazonspiceox/smoke/awscli.sh ]; then
                set_smoke_status "AMAZONSPICEOX_AWSCLI_INIT_SCRIPT_MISSING"
                log "awscli smoke script is missing or not executable"
                return 1
            fi
            if /usr/local/lib/amazonspiceox/smoke/awscli.sh; then
                log "awscli smoke completed successfully"
            else
                set_smoke_failure "$SMOKE_STATUS_FILE" "AMAZONSPICEOX_AWSCLI_SMOKE_FAIL" "awscli"
            fi
            ;;
        ssm)
            SMOKE_STATUS_FILE="$SMOKE_STATE_DIR/ssm.status"
            log "running requested Session Manager plugin smoke"
            set_smoke_status "AMAZONSPICEOX_SSM_PLUGIN_INIT_LAUNCHING_SCRIPT"
            if [ ! -x /usr/local/lib/amazonspiceox/smoke/ssm.sh ]; then
                set_smoke_status "AMAZONSPICEOX_SSM_PLUGIN_INIT_SCRIPT_MISSING"
                log "Session Manager plugin smoke script is missing or not executable"
                return 1
            fi
            if /usr/local/lib/amazonspiceox/smoke/ssm.sh; then
                log "Session Manager plugin smoke completed successfully"
            else
                set_smoke_failure "$SMOKE_STATUS_FILE" "AMAZONSPICEOX_SSM_PLUGIN_SMOKE_FAIL" "Session Manager plugin"
            fi
            ;;
        ssm-powerconnect)
            SMOKE_STATUS_FILE="$SMOKE_STATE_DIR/ssm-powerconnect.status"
            log "running requested SSM-PowerConnect smoke"
            set_smoke_status "AMAZONSPICEOX_SSM_POWERCONNECT_INIT_LAUNCHING_SCRIPT"
            if [ ! -x /usr/local/lib/amazonspiceox/smoke/ssm-powerconnect.sh ]; then
                set_smoke_status "AMAZONSPICEOX_SSM_POWERCONNECT_INIT_SCRIPT_MISSING"
                log "SSM-PowerConnect smoke script is missing or not executable"
                return 1
            fi
            if /usr/local/lib/amazonspiceox/smoke/ssm-powerconnect.sh; then
                log "SSM-PowerConnect smoke completed successfully"
            else
                set_smoke_failure "$SMOKE_STATUS_FILE" "AMAZONSPICEOX_SSM_POWERCONNECT_SMOKE_FAIL" "SSM-PowerConnect"
            fi
            ;;
        terraform)
            SMOKE_STATUS_FILE="$SMOKE_STATE_DIR/terraform.status"
            log "running requested terraform smoke"
            set_smoke_status "AMAZONSPICEOX_TERRAFORM_INIT_LAUNCHING_SCRIPT"
            if [ ! -x /usr/local/lib/amazonspiceox/smoke/terraform.sh ]; then
                set_smoke_status "AMAZONSPICEOX_TERRAFORM_INIT_SCRIPT_MISSING"
                log "terraform smoke script is missing or not executable"
                return 1
            fi
            if /usr/local/lib/amazonspiceox/smoke/terraform.sh; then
                log "terraform smoke completed successfully"
            else
                set_smoke_failure "$SMOKE_STATUS_FILE" "AMAZONSPICEOX_TERRAFORM_SMOKE_FAIL" "terraform"
            fi
            ;;
        kubectl)
            SMOKE_STATUS_FILE="$SMOKE_STATE_DIR/kubectl.status"
            log "running requested kubectl smoke"
            set_smoke_status "AMAZONSPICEOX_KUBECTL_INIT_LAUNCHING_SCRIPT"
            if [ ! -x /usr/local/lib/amazonspiceox/smoke/kubectl.sh ]; then
                set_smoke_status "AMAZONSPICEOX_KUBECTL_INIT_SCRIPT_MISSING"
                log "kubectl smoke script is missing or not executable"
                return 1
            fi
            if /usr/local/lib/amazonspiceox/smoke/kubectl.sh; then
                log "kubectl smoke completed successfully"
            else
                set_smoke_failure "$SMOKE_STATUS_FILE" "AMAZONSPICEOX_KUBECTL_SMOKE_FAIL" "kubectl"
            fi
            ;;
        docker)
            SMOKE_STATUS_FILE="$SMOKE_STATE_DIR/docker.status"
            log "running requested Docker smoke"
            set_smoke_status "AMAZONSPICEOX_DOCKER_INIT_LAUNCHING_SCRIPT"
            if [ ! -x /usr/local/lib/amazonspiceox/smoke/docker.sh ]; then
                set_smoke_status "AMAZONSPICEOX_DOCKER_INIT_SCRIPT_MISSING"
                log "Docker smoke script is missing or not executable"
                return 1
            fi
            if /usr/local/lib/amazonspiceox/smoke/docker.sh; then
                log "Docker smoke completed successfully"
            else
                set_smoke_failure "$SMOKE_STATUS_FILE" "AMAZONSPICEOX_DOCKER_SMOKE_FAIL" "Docker"
            fi
            ;;
        net|network)
            SMOKE_STATUS_FILE="$SMOKE_STATE_DIR/network.status"
            log "running requested network smoke"
            set_smoke_status "AMAZONSPICEOX_NETWORK_INIT_LAUNCHING_SCRIPT"
            if [ ! -x /usr/local/lib/amazonspiceox/smoke/network.sh ]; then
                set_smoke_status "AMAZONSPICEOX_NETWORK_INIT_SCRIPT_MISSING"
                log "network smoke script is missing or not executable"
                return 1
            fi
            if /usr/local/lib/amazonspiceox/smoke/network.sh; then
                log "network smoke completed successfully"
            else
                set_smoke_failure "$SMOKE_STATUS_FILE" "AMAZONSPICEOX_NETWORK_SMOKE_FAIL" "network"
            fi
            ;;
        apt)
            SMOKE_STATUS_FILE="$SMOKE_STATE_DIR/apt.status"
            log "running requested apt smoke"
            set_smoke_status "AMAZONSPICEOX_APT_INIT_LAUNCHING_SCRIPT"
            if [ ! -x /usr/local/lib/amazonspiceox/smoke/apt.sh ]; then
                set_smoke_status "AMAZONSPICEOX_APT_INIT_SCRIPT_MISSING"
                log "apt smoke script is missing or not executable"
                return 1
            fi
            if /usr/local/lib/amazonspiceox/smoke/apt.sh; then
                log "apt smoke completed successfully"
            else
                set_smoke_failure "$SMOKE_STATUS_FILE" "AMAZONSPICEOX_APT_SMOKE_FAIL" "apt"
            fi
            ;;
        *)
            log "unknown requested smoke mode: $SMOKE_MODE"
            ;;
    esac
}

finish_requested_smoke() {
    case "$SMOKE_MODE" in
        ""|none)
            return 0
            ;;
    esac

    log "requested smoke finished; asking the guest to power off"
    sync 2>/dev/null || true

    if command -v poweroff >/dev/null 2>&1; then
        poweroff -f >/dev/null 2>&1 && return 0
    fi

    if command -v halt >/dev/null 2>&1; then
        halt -f >/dev/null 2>&1 && return 0
    fi

    if command -v reboot >/dev/null 2>&1; then
        reboot -f >/dev/null 2>&1 && return 0
    fi

    log "falling back to sysrq-based shutdown"
    echo 1 > /proc/sys/kernel/sysrq 2>/dev/null || true
    echo s > /proc/sysrq-trigger 2>/dev/null || true
    sleep 1
    echo u > /proc/sysrq-trigger 2>/dev/null || true
    sleep 1
    echo o > /proc/sysrq-trigger 2>/dev/null || echo b > /proc/sysrq-trigger 2>/dev/null || true

    while true; do
        sleep 3600
    done
}

start_shell() {
    log "AmazonSpiceOx Phase III boot complete"
    log "active profile: $ACTIVE_PROFILE"
    echo
    echo "AmazonSpiceOx - Phase III"
    echo "AMAZONSPICEOX_PHASE3_BOOT_OK"
    echo "Profile: $ACTIVE_PROFILE"
    echo "Root filesystem: persistent ext4"
    echo "Kernel: $(uname -r)"
    echo

    while true; do
        interactive_shell
        log "interactive shell exited; restarting in 2 seconds"
        sleep 2
    done
}

setup_runtime_dirs
log "starting stage 2 userspace"
load_profile
mount_once proc /proc
mount_once sysfs /sys
read_boot_cmdline
configure_smoke_paths
set_smoke_status "AMAZONSPICEOX_SMOKE_INIT_STAGE2_READY"
setup_cgroups
setup_devices
setup_udev
setup_hostname
set_smoke_status "AMAZONSPICEOX_SMOKE_INIT_HOSTNAME_READY"
setup_network
set_smoke_status "AMAZONSPICEOX_SMOKE_INIT_NETWORK_READY"
setup_resolver
record_persistent_boot
run_requested_smoke
finish_requested_smoke
start_shell

#!/bin/sh

# AmazonSpiceOx stage 2 init.
# This is the real PID 1 after initramfs mounts the persistent rootfs and runs
# switch_root. It stays intentionally small and readable.

export PATH=/bin:/sbin:/usr/bin:/usr/sbin
export PS1='arrakis:\w# '
export HOME=/root
export TERM=linux
export ENV=/etc/profile

HOSTNAME_FILE=/etc/hostname
BOOT_LOG=/var/log/boot.log
PROFILE_FILE=/etc/amazonspiceox-profile
ACTIVE_PROFILE=base
SMOKE_MODE=none

log() {
    message="[init] $*"
    echo "$message"
    echo "$message" >> "$BOOT_LOG" 2>/dev/null || true
}

load_profile() {
    if [ -f "$PROFILE_FILE" ]; then
        ACTIVE_PROFILE="$(cat "$PROFILE_FILE")"
    fi
}

read_boot_cmdline() {
    for arg in $(cat /proc/cmdline 2>/dev/null || true); do
        case "$arg" in
            asox.smoke=*)
                SMOKE_MODE="${arg#asox.smoke=}"
                ;;
        esac
    done
}

emergency_shell() {
    log "entering emergency shell"
    log "type 'exit' to return to the init recovery loop"

    while true; do
        if command -v cttyhack >/dev/null 2>&1; then
            setsid cttyhack sh
        else
            setsid sh </dev/console >/dev/console 2>&1
        fi
        log "emergency shell exited; restarting in 2 seconds"
        sleep 2
    done
}

fail() {
    log "ERROR: $*"
    emergency_shell
}

mount_once() {
    fstype="$1"
    target="$2"

    if grep -qs " $target " /proc/mounts 2>/dev/null; then
        log "$target already mounted"
        return 0
    fi

    mount -t "$fstype" "$fstype" "$target" || fail "could not mount $target"
    log "mounted $target"
}

setup_runtime_dirs() {
    mkdir -p /proc /sys /dev /run /tmp /var/log /var/lib/amazonspiceox /root
    chmod 1777 /tmp
    : > "$BOOT_LOG" 2>/dev/null || true
}

setup_devices() {
    mount_once devtmpfs /dev

    [ -c /dev/console ] || mknod -m 600 /dev/console c 5 1 2>/dev/null || true
    [ -c /dev/null ] || mknod -m 666 /dev/null c 1 3 2>/dev/null || true
}

setup_hostname() {
    name="arrakis"

    if [ -f "$HOSTNAME_FILE" ]; then
        name="$(cat "$HOSTNAME_FILE")"
    fi

    hostname "$name" || fail "could not set hostname"
    log "hostname set to $name"
}

setup_network() {
    log "initializing loopback"
    if command -v ifup >/dev/null 2>&1; then
        ifup lo 2>/dev/null || true
    else
        ip link set lo up 2>/dev/null || ifconfig lo 127.0.0.1 up 2>/dev/null || true
    fi

    if command -v ifup >/dev/null 2>&1; then
        if ifup eth0 >/tmp/ifup-eth0.log 2>&1; then
            log "eth0 configured through ifup"
        else
            log "ifup eth0 failed; see /tmp/ifup-eth0.log"
        fi
        return 0
    fi

    if ip link set eth0 up 2>/dev/null || ifconfig eth0 up 2>/dev/null; then
        log "eth0 link is up"

        if command -v udhcpc >/dev/null 2>&1; then
            udhcpc -i eth0 -q -n -t 3 -T 2 >/tmp/udhcpc.log 2>&1 \
                && log "dhcp lease acquired on eth0" \
                || log "dhcp did not complete; see /tmp/udhcpc.log"
        elif command -v dhclient >/dev/null 2>&1; then
            dhclient -v eth0 >/tmp/dhclient-eth0.log 2>&1 \
                && log "dhcp lease acquired on eth0" \
                || log "dhclient did not complete; see /tmp/dhclient-eth0.log"
        fi
    else
        log "eth0 not available yet"
    fi
}

record_persistent_boot() {
    echo "booted from persistent rootfs" > /var/lib/amazonspiceox/rootfs-state
    sync 2>/dev/null || true
    log "persistent rootfs marker written to /var/lib/amazonspiceox/rootfs-state"
}

run_requested_smoke() {
    case "$SMOKE_MODE" in
        ""|none)
            return 0
            ;;
        apt)
            log "running requested apt smoke"
            if /usr/local/lib/amazonspiceox/smoke/apt.sh; then
                log "apt smoke completed successfully"
            else
                echo "AMAZONSPICEOX_APT_SMOKE_FAIL"
                printf '%s\n' "AMAZONSPICEOX_APT_SMOKE_FAIL" > /var/lib/amazonspiceox/smoke/apt.status 2>/dev/null || true
                sync 2>/dev/null || true
                log "apt smoke failed"
            fi
            ;;
        *)
            log "unknown requested smoke mode: $SMOKE_MODE"
            ;;
    esac
}

finish_requested_smoke() {
    case "$SMOKE_MODE" in
        ""|none)
            return 0
            ;;
    esac

    log "requested smoke finished; asking the guest to power off"
    sync 2>/dev/null || true
    poweroff -f >/dev/null 2>&1 || halt -f >/dev/null 2>&1 || reboot -f >/dev/null 2>&1 || true
}

start_shell() {
    log "AmazonSpiceOx Phase III boot complete"
    log "active profile: $ACTIVE_PROFILE"
    echo
    echo "AmazonSpiceOx - Phase III"
    echo "AMAZONSPICEOX_PHASE3_BOOT_OK"
    echo "Profile: $ACTIVE_PROFILE"
    echo "Root filesystem: persistent ext4"
    echo "Kernel: $(uname -r)"
    echo

    while true; do
        if command -v cttyhack >/dev/null 2>&1; then
            setsid cttyhack sh
        else
            setsid sh </dev/console >/dev/console 2>&1
        fi
        log "interactive shell exited; restarting in 2 seconds"
        sleep 2
    done
}

setup_runtime_dirs
log "starting stage 2 userspace"
load_profile
mount_once proc /proc
mount_once sysfs /sys
read_boot_cmdline
setup_devices
setup_hostname
setup_network
record_persistent_boot
run_requested_smoke
finish_requested_smoke
start_shell

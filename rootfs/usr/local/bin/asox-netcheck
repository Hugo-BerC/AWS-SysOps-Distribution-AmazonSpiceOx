#!/bin/sh
set -eu

echo "[asox-netcheck] hostname"
hostname || true
echo

echo "[asox-netcheck] eth0"
ip addr show dev eth0 2>/dev/null || true
echo

echo "[asox-netcheck] routes"
ip route show 2>/dev/null || true
echo

echo "[asox-netcheck] resolv.conf"
cat /etc/resolv.conf 2>/dev/null || true
echo

echo "[asox-netcheck] hosts"
cat /etc/hosts 2>/dev/null || true
echo

echo "[asox-netcheck] nsswitch.conf"
cat /etc/nsswitch.conf 2>/dev/null || true
echo

echo "[asox-netcheck] ifup log"
cat /tmp/ifup-eth0.log 2>/dev/null || true
echo

echo "[asox-netcheck] dhclient log"
cat /tmp/dhclient-eth0.log 2>/dev/null || true
echo

echo "[asox-netcheck] getent hosts deb.debian.org"
getent hosts deb.debian.org 2>/dev/null || true
echo

if [ -n "${ASOX_NETCHECK_DNS_HOST:-}" ]; then
    echo "[asox-netcheck] getent hosts $ASOX_NETCHECK_DNS_HOST"
    getent hosts "$ASOX_NETCHECK_DNS_HOST" 2>/dev/null || true
    echo

    if command -v curl >/dev/null 2>&1; then
        echo "[asox-netcheck] curl https://$ASOX_NETCHECK_DNS_HOST/"
        curl --connect-timeout 5 --max-time 10 -I "https://$ASOX_NETCHECK_DNS_HOST/" || true
        echo
    fi
fi

echo "[asox-netcheck] ping 10.0.2.2"
ping -c 1 10.0.2.2 2>/dev/null || true
echo

echo "[asox-netcheck] getent hosts host.qemu.internal"
getent hosts host.qemu.internal 2>/dev/null || true
echo

echo "[asox-netcheck] ping host.qemu.internal"
ping -c 1 host.qemu.internal 2>/dev/null || true
echo

echo "[asox-netcheck] getent hosts host.os.internal"
getent hosts host.os.internal 2>/dev/null || true
echo

echo "[asox-netcheck] ping host.os.internal"
ping -c 1 host.os.internal 2>/dev/null || true
echo

echo "[asox-netcheck] getent hosts host.windows.internal"
getent hosts host.windows.internal 2>/dev/null || true
echo

echo "[asox-netcheck] ping host.windows.internal"
ping -c 1 host.windows.internal 2>/dev/null || true
echo

echo "[asox-netcheck] ping 1.1.1.1"
ping -c 1 1.1.1.1 2>/dev/null || true
echo

echo "[asox-netcheck] ping deb.debian.org"
ping -c 1 deb.debian.org 2>/dev/null || true
echo

if [ -n "${ASOX_HOST_TEST_URL:-}" ]; then
    echo "[asox-netcheck] curl $ASOX_HOST_TEST_URL"
    if command -v curl >/dev/null 2>&1; then
        curl --connect-timeout 5 --max-time 10 -v "$ASOX_HOST_TEST_URL" || true
    else
        echo "curl not installed in this profile"
    fi
    echo
fi

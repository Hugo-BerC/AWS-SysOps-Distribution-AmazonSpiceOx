#!/bin/sh
set -eu

mode="${1:-auto}"
resolv_conf="${ASOX_RESOLV_CONF:-/etc/resolv.conf}"
tmp_resolv="/tmp/resolv.conf.amazonspiceox.$$"

is_wsl() {
    grep -qi microsoft /proc/sys/kernel/osrelease 2>/dev/null
}

add_nameserver() {
    server="$1"
    [ -n "$server" ] || return 0
    grep -Eq "^[[:space:]]*nameserver[[:space:]]+$server([[:space:]]|$)" "$tmp_resolv" 2>/dev/null && return 0
    printf 'nameserver %s\n' "$server" >> "$tmp_resolv"
}

copy_existing_nameservers() {
    [ -s "$resolv_conf" ] || return 0
    awk '/^nameserver[[:space:]]/ { print $2 }' "$resolv_conf" 2>/dev/null | while IFS= read -r server; do
        add_nameserver "$server"
    done
}

if [ "$(id -u)" -ne 0 ]; then
    echo "asox-dns-fix: must run as root" >&2
    exit 1
fi

: > "$tmp_resolv"
printf '# Generated by asox-dns-fix\n' >> "$tmp_resolv"

case "$mode" in
    auto|wsl|google)
        add_nameserver 8.8.8.8
        add_nameserver 1.1.1.1
        ;;
    cloudflare)
        add_nameserver 1.1.1.1
        add_nameserver 8.8.8.8
        ;;
    qemu)
        add_nameserver 8.8.8.8
        add_nameserver 1.1.1.1
        add_nameserver 10.0.2.3
        ;;
    *)
        echo "usage: asox-dns-fix [auto|google|cloudflare|qemu|wsl]" >&2
        rm -f "$tmp_resolv"
        exit 2
        ;;
esac

if [ "$mode" = "auto" ] && ! is_wsl; then
    add_nameserver 10.0.2.3
fi

copy_existing_nameservers
printf 'options timeout:1 attempts:2\n' >> "$tmp_resolv"

install -m 0644 "$tmp_resolv" "$resolv_conf"
rm -f "$tmp_resolv"

if [ "${ASOX_DNS_FIX_QUIET:-0}" != "1" ]; then
    echo "DNS resolver updated at $resolv_conf"
    cat "$resolv_conf"
fi

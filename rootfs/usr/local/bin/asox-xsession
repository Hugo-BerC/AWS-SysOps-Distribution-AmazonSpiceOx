#!/bin/sh
set -eu

export HOME="${HOME:-/root}"
export USER="${USER:-root}"
export SHELL="${SHELL:-/bin/bash}"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp/xdg-runtime-root}"
keyboard_layout="${ASOX_KEYBOARD_LAYOUT:-es}"

ensure_system_dbus() {
    dbus_socket="/run/dbus/system_bus_socket"

    if command -v dbus-send >/dev/null 2>&1; then
        if [ -S "$dbus_socket" ] && dbus-send --system --dest=org.freedesktop.DBus --type=method_call --print-reply / org.freedesktop.DBus.ListNames >/dev/null 2>&1; then
            return 0
        fi
    elif [ -S "$dbus_socket" ]; then
        return 0
    fi

    mkdir -p /run/dbus /var/lib/dbus
    rm -f "$dbus_socket"

    if command -v dbus-uuidgen >/dev/null 2>&1; then
        dbus-uuidgen --ensure=/etc/machine-id >/dev/null 2>&1 || true
        dbus-uuidgen --ensure >/dev/null 2>&1 || true
    fi

    dbus-daemon --system --fork >/tmp/dbus-system.log 2>&1 || true
}

mkdir -p "$HOME/.config" "$HOME/.cache" "$XDG_RUNTIME_DIR"
chmod 700 "$XDG_RUNTIME_DIR" 2>/dev/null || true

if command -v dbus-daemon >/dev/null 2>&1; then
    ensure_system_dbus
fi

if command -v dbus-launch >/dev/null 2>&1; then
    eval "$(dbus-launch --sh-syntax --exit-with-session 2>/dev/null)" || true
fi

if command -v spice-vdagent >/dev/null 2>&1; then
    if [ -e /dev/virtio-ports/com.redhat.spice.0 ]; then
        spice-vdagent >/tmp/spice-vdagent.log 2>&1 &
    else
        echo "spice-vdagent: /dev/virtio-ports/com.redhat.spice.0 not found" > /tmp/spice-vdagent.log
    fi
fi

if command -v xsetroot >/dev/null 2>&1; then
    xsetroot -solid "#1f2430" >/dev/null 2>&1 || true
fi

if command -v setxkbmap >/dev/null 2>&1; then
    setxkbmap "$keyboard_layout" >/tmp/setxkbmap.log 2>&1 || true
fi

if command -v openbox >/dev/null 2>&1; then
    openbox >/tmp/openbox.log 2>&1 &
fi

if [ "$#" -eq 0 ]; then
    if command -v asox-terminal >/dev/null 2>&1; then
        exec asox-terminal
    fi
    exec /bin/bash --login
fi

exec "$@"

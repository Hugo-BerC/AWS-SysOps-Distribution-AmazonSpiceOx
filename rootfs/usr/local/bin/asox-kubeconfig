#!/bin/sh
set -eu

target_path="${KUBECONFIG:-/root/.kube/config}"
target_dir="$(dirname "$target_path")"

usage() {
    cat <<'EOF'
usage:
  asox-kubeconfig status
  asox-kubeconfig path
  asox-kubeconfig init
  asox-kubeconfig install <file>
  asox-kubeconfig install-stdin
  asox-kubeconfig show
EOF
}

ensure_dir() {
    mkdir -p "$target_dir"
    chmod 0700 "$target_dir"
}

cmd="${1:-status}"

case "$cmd" in
    status)
        echo "KUBECONFIG=$target_path"
        if [ -f "$target_path" ]; then
            ls -l "$target_path"
        else
            echo "missing"
        fi
        ;;
    path)
        echo "$target_path"
        ;;
    init)
        ensure_dir
        cat > "$target_path" <<'EOF'
apiVersion: v1
kind: Config
preferences: {}
clusters: []
users: []
contexts: []
current-context: ""
EOF
        chmod 0600 "$target_path"
        echo "initialized $target_path"
        ;;
    install)
        src_file="${2:?source kubeconfig path required}"
        if [ ! -f "$src_file" ]; then
            echo "error: source kubeconfig not found: $src_file" >&2
            exit 1
        fi
        ensure_dir
        cp "$src_file" "$target_path"
        chmod 0600 "$target_path"
        echo "installed kubeconfig at $target_path"
        ;;
    install-stdin)
        ensure_dir
        cat > "$target_path"
        chmod 0600 "$target_path"
        echo "installed kubeconfig at $target_path"
        ;;
    show)
        if [ ! -f "$target_path" ]; then
            echo "error: kubeconfig not found: $target_path" >&2
            exit 1
        fi
        cat "$target_path"
        ;;
    *)
        usage >&2
        exit 1
        ;;
esac
